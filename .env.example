# ===== Telegram Bot =====
BOT_TOKEN="123456:ABC-DEF_your_bot_token_here"
# Botning username (Web App tugmasi uchun ixtiyoriy)
BOT_USERNAME="oquv_markaz_bot"

# ===== Database (PostgreSQL) =====
# Lokal Docker uchun (docker compose up -d):
DATABASE_URL="postgresql://oquv:oquv123@localhost:5433/oquv_markaz?schema=public"
# Supabase uchun: postgresql://postgres:[PAROL]@db.[REF].supabase.co:5432/postgres

# ===== App URL (Mini App) =====
# Telegram Web App ochiladigan HTTPS URL (Vercel domeni)
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# ===== Admin auth =====
# JWT imzolash uchun maxfiy kalit (uzun random string qo'ying)
