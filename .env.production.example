# ====================================================================
# PRODUCTION .env  —  serverda shu faylni `.env` nomi bilan saqlang:
#   cp .env.production.example .env   va qiymatlarni to'ldiring
# ====================================================================

# ---------- Domen (Mini App HTTPS uchun SHART) ----------
# Domeningiz yo'q bo'lsa, server IP'sidan bepul subdomen ishlating (nip.io):
#   IP 203.0.113.45 bo'lsa  ->  APP_DOMAIN=203.0.113.45.nip.io
# Domeningiz bo'lsa shunchaki:  APP_DOMAIN=markaz.uz
APP_DOMAIN=YOUR_SERVER_IP.nip.io

# Mini App ochiladigan to'liq HTTPS manzil (APP_DOMAIN bilan bir xil host)
NEXT_PUBLIC_APP_URL=https://YOUR_SERVER_IP.nip.io

# ---------- Telegram bot ----------
BOT_TOKEN=8899847907:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BOT_USERNAME=markazTop_bot

# ---------- PostgreSQL ----------
POSTGRES_USER=oquv
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=oquv_markaz
# DATABASE_URL host = "db" (compose servis nomi), port = 5432 (konteyner ichida)
# Parol POSTGRES_PASSWORD bilan AYNAN bir xil bo'lsin:
DATABASE_URL=postgresql://oquv:CHANGE_ME_strong_password@db:5432/oquv_markaz?schema=public

# ---------- Admin panel ----------
# Uzun tasodifiy satr qo'ying (masalan: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_to_a_long_random_secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_admin_password
# Telegram ID bo'yicha adminlar (vergul bilan): botda /start -> admin panel
ADMIN_TELEGRAM_IDS=5944670152
