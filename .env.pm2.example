# ====================================================================
# PRODUCTION .env  —  PM2 deploy uchun (baza Docker'da, ilova+bot PM2'da)
#   cp .env.pm2.example .env   va qiymatlarni to'ldiring
# ====================================================================

# ---------- Mini App ochiladigan manzil ----------
# nginx orqali ko'rinadigan to'liq manzil.
# HTTPS bo'lsa Mini App tugmasi chiqadi. HTTP bo'lsa bot matnli havola yuboradi.
#   domen bilan:  https://markaz.uz
#   IP bilan:     http://203.0.113.45
NEXT_PUBLIC_APP_URL=https://markaz.uz

# ---------- Telegram bot ----------
BOT_TOKEN=8899847907:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BOT_USERNAME=markazTop_bot

# ---------- PostgreSQL (docker-compose.db.yml) ----------
POSTGRES_USER=oquv
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=oquv_markaz
# DIQQAT: host = localhost, port = 5433 (konteyner 127.0.0.1:5433 ga chiqaradi).
# Parol POSTGRES_PASSWORD bilan AYNAN bir xil bo'lsin:
DATABASE_URL=postgresql://oquv:CHANGE_ME_strong_password@localhost:5433/oquv_markaz?schema=public

# ---------- Admin panel ----------
JWT_SECRET=CHANGE_ME_to_a_long_random_secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_admin_password
# Telegram ID bo'yicha adminlar — vergul bilan ajrating: "111,222"
# Bu ID egasi botda /start bosganda to'g'ridan-to'g'ri admin panel ochiladi.
ADMIN_TELEGRAM_IDS=5944670152
